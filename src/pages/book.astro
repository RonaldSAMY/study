---
import Layout from '../components/Layout.astro';
import { BOOK, BOOK_META, coverageStats } from '../data/bookMap';
import { getLessonBySlug } from '../data/curriculum';
import { url } from '../lib/url';

const { total, covered } = coverageStats();
const pct = Math.round((covered / total) * 100);
const parts = [
  { id: 'I', label: 'Part I — Mathematical Foundations' },
  { id: 'II', label: 'Part II — Central Machine Learning Problems' },
] as const;
---

<Layout title="Book Map · Maths for ML" description="How this site maps onto every chapter and section of Mathematics for Machine Learning.">
  <header class="animate-fade-up">
    <h1 class="text-3xl font-extrabold sm:text-4xl">📖 Book Map</h1>
    <p class="mt-3 max-w-2xl text-lg text-muted">
      How this course lines up with every chapter of <em>{BOOK_META.title}</em>
      ({BOOK_META.authors}, {BOOK_META.year}). Click any covered section to jump to the lesson.
    </p>
    <div class="mt-5 flex flex-wrap items-center gap-4">
      <a href={BOOK_META.url} target="_blank" rel="noopener" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-semibold transition hover:border-brand">
        Visit mml-book.com ↗
      </a>
      <div class="flex items-center gap-3">
        <div class="h-2 w-40 overflow-hidden rounded-full bg-surface-2">
          <div class="h-full rounded-full bg-calculus" style={`width:${pct}%`}></div>
        </div>
        <span class="text-sm font-semibold text-muted">{covered}/{total} sections mapped ({pct}%)</span>
      </div>
    </div>
    <p class="mt-3 text-sm text-muted">
      A few sections (e.g. graphical models, matrix phylogeny) are noted in the book but, being brief asides,
      live inside related lessons rather than standalone pages.
    </p>
  </header>

  {parts.map((part) => (
    <section class="mt-10">
      <div class="mb-4 flex items-center gap-3">
        <h2 class="text-2xl font-extrabold">{part.label}</h2>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="space-y-4">
        {BOOK.filter((c) => c.part === part.id).map((ch) => (
          <div class="rounded-2xl border border-border bg-surface p-5">
            <h3 class="mb-3 text-lg font-bold">
              <span class="text-muted">Chapter {ch.n}</span> · {ch.title}
            </h3>
            <ul class="grid gap-1.5">
              {ch.sections.map((s) => {
                const lessons = (s.slugs ?? []).map((sl) => getLessonBySlug(sl)).filter(Boolean);
                return (
                  <li class="flex flex-wrap items-center gap-x-2 gap-y-1 rounded-lg px-2 py-1.5 text-sm hover:bg-surface-2">
                    <span class="w-10 shrink-0 font-mono text-muted">{s.sec}</span>
                    <span class="min-w-[12rem] flex-1 font-medium">{s.title}</span>
                    {lessons.length > 0 ? (
                      <span class="flex flex-wrap items-center gap-1.5">
                        <span class="text-calculus">✓</span>
                        {lessons.map((l) => (
                          <a href={url(`/${l!.slug}`)} class="rounded-full bg-brand-soft px-2.5 py-0.5 text-xs font-semibold text-brand hover:underline">
                            {l!.trackIcon} {l!.title}
                          </a>
                        ))}
                      </span>
                    ) : (
                      <span class="text-xs text-muted">— in-text aside</span>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>
    </section>
  ))}
</Layout>
