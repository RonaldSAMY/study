---
import Layout from '../components/Layout.astro';
import { ALL_LESSONS, TOTAL_COUNT, COURSES, tracksForCourse } from '../data/curriculum';
import { getReadySlugs } from '../lib/lessons';
import { url } from '../lib/url';

const readySet = await getReadySlugs();
const READY_COUNT = readySet.size;

// Per-course stats + a "start here" link.
const courseCards = COURSES.map((c) => {
  const tracks = tracksForCourse(c.id);
  const slugs = tracks.flatMap((t) => t.lessons.map((l) => `${t.id}/${l.id}`));
  const ready = slugs.filter((s) => readySet.has(s)).length;
  const firstTrack = tracks[0];
  const start = firstTrack ? `${firstTrack.id}/${firstTrack.lessons[0].id}` : '';
  return { ...c, trackCount: tracks.length, lessonCount: slugs.length, ready, start };
});

// Curated showcase lessons (the most interactive demos).
const FEATURED = [
  'linear-algebra/vectors',
  'calculus-1/derivative',
  'transformers/attention',
  'trigonometry/unit-circle',
];
const flagships = FEATURED
  .map((slug) => ALL_LESSONS.find((l) => l.slug === slug))
  .filter((l): l is NonNullable<typeof l> => Boolean(l) && readySet.has(l!.slug));
---

<Layout>
  <!-- Hero -->
  <section class="animate-fade-up py-6 text-center sm:py-10">
    <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-4 py-1.5 text-sm font-semibold text-muted">
      🎓 Two interactive courses · from first principles to the frontier
    </p>
    <h1 class="mx-auto max-w-3xl text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl md:text-6xl">
      Learn the <span class="text-brand">hard things</span>, finally made intuitive
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-muted">
      Pick a path below. Every idea is built on the last and explained with plain language, simple
      animations, hands-on interactive demos and fresh real-world examples each time.
    </p>
    <p class="mt-5 text-sm text-muted">{READY_COUNT} interactive lessons live · {TOTAL_COUNT} mapped across both courses</p>
  </section>

  <!-- Course chooser -->
  <section class="mt-6 grid gap-5 md:grid-cols-2">
    {courseCards.map((c) => (
      <a href={c.start ? url(`/${c.start}`) : url('/path')} class="group flex flex-col rounded-2xl border border-border bg-surface p-7 transition hover:-translate-y-0.5 hover:border-brand hover:shadow-lg">
        <div class="text-5xl">{c.icon}</div>
        <h2 class="mt-4 text-2xl font-extrabold group-hover:text-brand">{c.title}</h2>
        <p class="mt-2 flex-1 text-muted">{c.blurb}</p>
        <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold">
          <span class="rounded-full bg-surface-2 px-2.5 py-1 text-muted">{c.trackCount} tracks</span>
          <span class="rounded-full bg-surface-2 px-2.5 py-1 text-muted">{c.lessonCount} lessons</span>
          <span class="rounded-full bg-calculus/15 px-2.5 py-1 text-calculus">{c.ready} ready</span>
        </div>
        <span class="mt-5 inline-block font-semibold text-brand">Start learning →</span>
      </a>
    ))}
  </section>

  <!-- What makes it different -->
  <section class="mt-14 grid gap-4 sm:grid-cols-3">
    {[
      { icon: '🧠', t: 'Intuition first', d: 'Understand the idea before any formula. Pictures and plain language lead every lesson.' },
      { icon: '🎮', t: 'Learn by doing', d: 'Drag, slide and simulate. Interactive demos turn abstract ideas into something you can feel.' },
      { icon: '🌍', t: 'Always a new example', d: 'Each concept is shown through several different real-world stories — never the same one twice.' },
    ].map((f) => (
      <div class="rounded-2xl border border-border bg-surface p-6">
        <div class="text-3xl">{f.icon}</div>
        <h3 class="mt-3 text-lg font-bold">{f.t}</h3>
        <p class="mt-1 text-sm text-muted">{f.d}</p>
      </div>
    ))}
  </section>

  <!-- Flagship lessons -->
  <section class="mt-14">
    <h2 class="text-2xl font-extrabold">Start here — fully interactive lessons</h2>
    <p class="mt-1 text-muted">Polished, end-to-end examples of how every topic is taught.</p>
    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      {flagships.map((l) => (
        <a href={url(`/${l.slug}`)} class="group rounded-2xl border border-border bg-surface p-5 transition hover:-translate-y-0.5 hover:border-brand hover:shadow-lg">
          <div class="flex items-center gap-2">
            <span class="text-2xl">{l.trackIcon}</span>
            <span class="rounded-full bg-brand-soft px-2.5 py-0.5 text-xs font-semibold text-brand">{l.trackTitle}</span>
          </div>
          <h3 class="mt-3 text-lg font-bold group-hover:text-brand">{l.title}</h3>
          <p class="mt-1 text-sm text-muted">{l.summary}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand">Open lesson →</span>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-16 rounded-2xl border border-brand/30 bg-brand-soft p-8 text-center">
    <h2 class="text-2xl font-extrabold text-brand">See everything at a glance</h2>
    <p class="mx-auto mt-2 max-w-xl text-muted">Browse the full curriculum of both courses — every stage, track and lesson in order.</p>
    <a href={url('/path')} class="mt-6 inline-block rounded-xl bg-brand px-6 py-3.5 font-semibold text-white shadow-lg transition hover:brightness-110">Open the learning paths →</a>
  </section>
</Layout>
