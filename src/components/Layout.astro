---
import '../styles/tokens.css';
import Sidebar from './Sidebar.astro';
import ThemeToggle from './ThemeToggle.tsx';
import { TOTAL_COUNT } from '../data/curriculum';
import { getReadySlugs } from '../lib/lessons';

const READY_COUNT = (await getReadySlugs()).size;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Maths for Machine Learning — Interactive Foundations',
  description = 'Learn the mathematics behind machine learning from the ground up: algebra, geometry, trigonometry, calculus, linear algebra, probability and statistics — with intuition, animations and interactive demos.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>∑</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <!-- Set theme before paint to avoid a flash -->
    <script is:inline>
      (() => {
        const s = localStorage.getItem('theme');
        const d = s ? s === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', d);
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <div class="flex min-h-screen flex-col lg:flex-row">
      <!-- Mobile top bar -->
      <header class="sticky top-0 z-40 flex items-center justify-between border-b border-border bg-surface/80 px-4 py-3 backdrop-blur lg:hidden">
        <a href="/" class="flex items-center gap-2 font-extrabold">
          <span class="text-brand">∑</span> Maths for ML
        </a>
        <div class="flex items-center gap-2">
          <ThemeToggle client:load />
          <button id="nav-toggle" aria-label="Open navigation" class="grid h-9 w-9 place-items-center rounded-lg border border-border bg-surface">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
          </button>
        </div>
      </header>

      <Sidebar />

      <main class="min-w-0 flex-1">
        <div class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 lg:px-10 lg:py-12">
          <div class="mb-6 hidden items-center justify-between lg:flex">
            <p class="text-sm text-muted">
              {READY_COUNT} interactive lessons live · {TOTAL_COUNT} in the full path
            </p>
            <ThemeToggle client:load />
          </div>
          <slot />
        </div>
        <footer class="border-t border-border px-6 py-10 text-center text-sm text-muted">
          <p>Built as an interactive companion for <em>Mathematics for Machine Learning</em>.</p>
          <p class="mt-1">Intuition first · multiple real-world examples · learn by doing.</p>
        </footer>
      </main>
    </div>

    <script>
      // Mobile drawer toggle + progress checkmark sync for the sidebar.
      const toggle = document.getElementById('nav-toggle');
      const sidebar = document.getElementById('sidebar');
      toggle?.addEventListener('click', () => sidebar?.classList.toggle('hidden'));

      function syncProgress() {
        let done = new Set();
        try { done = new Set(JSON.parse(localStorage.getItem('mml-progress-v1') || '[]')); } catch {}
        document.querySelectorAll('[data-lesson-slug]').forEach((el) => {
          const slug = el.getAttribute('data-lesson-slug');
          el.querySelector('[data-check]')?.classList.toggle('opacity-0', !done.has(slug));
        });
      }
      syncProgress();
      window.addEventListener('mml:progress', syncProgress);
      window.addEventListener('storage', syncProgress);
    </script>
  </body>
</html>
