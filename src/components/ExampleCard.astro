---
// A single real-world example. Lessons stack several of these, each from a
// DIFFERENT domain, to build intuition without reusing the same scenario.
interface Props {
  domain: string;   // e.g. "Navigation", "Physics", "Recommender systems"
  icon?: string;    // emoji
}
const { domain, icon = '🌍' } = Astro.props;
---
<div class="not-prose my-4 overflow-hidden rounded-xl border border-border bg-surface">
  <div class="flex items-center gap-2 border-b border-border bg-surface-2 px-4 py-2">
    <span class="text-lg">{icon}</span>
    <span class="text-xs font-bold uppercase tracking-wide text-muted">Real-world example</span>
    <span class="ml-auto rounded-full bg-brand-soft px-2.5 py-0.5 text-xs font-semibold text-brand">{domain}</span>
  </div>
  <div class="p-4 text-[0.95rem] leading-relaxed [&_p]:my-2 [&_:last-child]:mb-0">
    <slot />
  </div>
</div>
